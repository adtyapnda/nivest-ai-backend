# Copy to .env and fill in. Everything has a working dev default, so the app
# runs without any of these set (live integrations just fall back to seeded data).

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=10080

# CORS (comma separated). Defaults cover the Vite dev server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Live market data (Yahoo Finance via yfinance needs no key).
# Set to 0 to skip live fetches and always use seeded prices.
ENABLE_LIVE_MARKET=1

# Tickertape news (best-effort; falls back to seeded news on failure).
ENABLE_LIVE_NEWS=1

# Parasram data/broker API (placeholder seam — friend will provide these).
PARASRAM_API_BASE=
PARASRAM_API_KEY=

# Razorpay (leave blank for a stubbed checkout that returns a demo message).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Groq — powers the AI Chat. Get a key at https://console.groq.com/keys
# Without this the /chat endpoint returns 503 and the chat shows an error message.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
